<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.orderapi.mapper.RecordMapper">

    <select id="pageCC" resultType="com.orderapi.entity.RecordRes">
        select a.*,b.device_name deviceName,
               (select u.name from user u where u.id=a.user_id)username,
               (select u.name from user u where u.id=a.admin_id)adminname
        from record a,device b
            ${ew.customSqlSegment}
        order by (create_time) desc
    </select>

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.orderapi.entity.Record">
        <id column="id" property="id" />
        <result column="admin_id" property="adminId" />
        <result column="user_id" property="userId" />
        <result column="device_id" property="deviceId" />
        <result column="count" property="count" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, admin_id, user_id, device_id, count, create_time, update_time
    </sql>

</mapper>
